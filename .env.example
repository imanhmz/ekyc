# ─── BLOCKCHAIN ───────────────────────────────────────────────────────────────
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0x
PRIVATE_KEY=0x

# ─── ZKP (set ZKP_ENABLED=false to skip proof generation in dev) ──────────────
ZKP_ENABLED=false
ZKP_ARTIFACTS_PATH=/var/www/kyc/backend/zkp-artifacts
VERIFIER_ADDRESS=0x
AGE_VERIFIER_ADDRESS=0x
ATTRIBUTE_REGISTRY_ADDRESS=0x

# ─── S3 OBJECT STORAGE (SeaweedFS) ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:8333
S3_BUCKET=kyc-documents
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme

# ─── MULTI-BANK ───────────────────────────────────────────────────────────────
VIEWER_BANK_PORT=3001
SIGNER_BANK_URL=http://localhost:3000
# VIEWER_BANK_PRIVATE_KEY=0x   # optional: pin viewer bank secp256k1 keypair

# ─── INFRA (defaults already set in docker-compose.yml) ──────────────────────
# RABBITMQ_URL=amqp://kyc_mq:kyc_mq_pass@localhost:5672
# IPFS_API_URL=http://localhost:5001
# IPFS_GATEWAY_URL=http://localhost:8080
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=kyc_user
# DATABASE_PASSWORD=kyc_pass
# DATABASE_NAME=kyc_db
